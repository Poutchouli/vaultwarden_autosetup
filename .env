# ============================================================
# Vaultwarden - Configuration (.env)
# ============================================================
# Copiez ce fichier et adaptez les valeurs à votre environnement.
# Ne partagez JAMAIS ce fichier (il contient des secrets).

# --- Duck DNS ---
# Sous-domaine Duck DNS (sans .duckdns.org)
DUCKDNS_SUBDOMAIN=ma-vault
# Token Duck DNS (récupéré sur https://www.duckdns.org)
DUCKDNS_TOKEN=a3d958de-1f7a-4012-9bd8-52ba32993bee

# --- Domaine ---
# URL complète du serveur (avec https://)
# Si HTTPS n'utilise pas le port 443, ajoutez le port ici, par ex.:
#   https://ma-vault.duckdns.org:8443
VAULTWARDEN_DOMAIN=https://ma-vault.duckdns.org:8443

# --- Ports exposés par Caddy sur l'hôte ---
# Adaptez ces ports si 80/443 sont déjà utilisés sur le serveur.
# Le port HTTPS doit correspondre au port utilisé dans VAULTWARDEN_DOMAIN.
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443

# --- Email ---
# Email de contact pour les certificats Let's Encrypt
CONTACT_EMAIL=admin@va-vault.com

# --- Admin ---
# Token hashé Argon2id pour le panneau d'administration (/admin)
# ⚠️  Les '$' doivent être doublés '$$' pour éviter l'interpolation par Docker Compose.
#
# Pour générer un nouveau hash :
#   docker run --rm -it vaultwarden/server /vaultwarden hash
# Puis remplacez chaque '$' par '$$' dans le résultat avant de le coller ici.
#
ADMIN_TOKEN=$$argon2id$$v=19$$m=65540,t=3,p=4$$nOnv9k7log2CAOMWlu44uDamfddEjr3VZ61QEZ6PpMo$$YIhDogk4el0s+uiEkRSzY80hAvcuskfn5O2HIPpgJ4U

# --- Inscriptions ---
# Autoriser les nouvelles inscriptions (mettre à false après création des comptes)
SIGNUPS_ALLOWED=true
# Autoriser les invitations par les utilisateurs existants
INVITATIONS_ALLOWED=true
# Afficher les indices de mot de passe (déconseillé)
SHOW_PASSWORD_HINT=false

# --- Logs Caddy ---
LOG_FILE=/data/access.log
