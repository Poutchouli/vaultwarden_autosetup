  <script>
    function copyServerUrl() {
      const input = document.getElementById('server-url');
      const feedback = document.getElementById('copy-feedback');

      navigator.clipboard.writeText(input.value).then(function () {
        feedback.textContent = 'URL copiee. Vous pouvez maintenant la coller dans l\'extension.';
      }).catch(function () {
        input.focus();
        input.select();
        feedback.textContent = 'Copie automatique indisponible. Selectionnez l\'URL puis copiez-la manuellement.';
      });
    }
  </script>
